generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  name         String?
  image        String?
  createdAt    DateTime            @default(now())
  programs     Program[]
  sessions     WorkoutSession[]    @relation("Owner")
  sets         SessionSet[]
  partners     SessionPartner[]
  authSessions BetterAuthSession[]
  accounts     BetterAuthAccount[]
}

model Exercise {
  id            String            @id @default(cuid())
  name          String
  description   String            @db.Text
  instructions  Json
  primaryMuscle String
  muscles       String[]
  equipment     String?
  level         String
  imageUrl      String?
  imageUrl2     String?
  category      String
  isCustom      Boolean           @default(false)
  createdBy     String?
  programItems  ProgramExercise[]
  sets          SessionSet[]
}

model Program {
  id          String            @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id])
  exercises   ProgramExercise[]
  sessions    WorkoutSession[]
}

model ProgramExercise {
  id         String   @id @default(cuid())
  programId  String
  exerciseId String
  sets       Int      @default(3)
  reps       Int      @default(10)
  weightKg   Float?
  sortOrder  Int
  program    Program  @relation(fields: [programId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
}

model WorkoutSession {
  id          String           @id @default(cuid())
  programId   String
  ownerId     String
  mode        Mode             @default(SOLO)
  startedAt   DateTime         @default(now())
  finishedAt  DateTime?
  inviteToken String?          @unique
  program     Program          @relation(fields: [programId], references: [id])
  owner       User             @relation("Owner", fields: [ownerId], references: [id])
  sets        SessionSet[]
  partners    SessionPartner[]
}

enum Mode {
  SOLO
  PARTNER
}

model SessionSet {
  id          String         @id @default(cuid())
  sessionId   String
  exerciseId  String
  userId      String
  setNumber   Int
  weightKg    Float
  reps        Int
  completedAt DateTime       @default(now())
  session     WorkoutSession @relation(fields: [sessionId], references: [id])
  exercise    Exercise       @relation(fields: [exerciseId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
}

model SessionPartner {
  id        String         @id @default(cuid())
  sessionId String
  userId    String
  role      PartnerRole
  status    PartnerStatus  @default(INVITED)
  joinedAt  DateTime?
  session   WorkoutSession @relation(fields: [sessionId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
}

enum PartnerRole {
  TRAINER
  ATHLETE
}

enum PartnerStatus {
  INVITED
  ACTIVE
  DECLINED
}

model BetterAuthSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BetterAuthAccount {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BetterAuthVerification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
